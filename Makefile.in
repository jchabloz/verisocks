#Makefile

SHELL = @SHELL@

SRCDIR = .
BUILDDIR = build
INCDIRS += $(SRCDIR)/include
LIBVPI = $(BUILDDIR)/verisocks.vpi
DOCSDIR = docs

CC = @CC@
CFLAGS = @CFLAGS@
LDFLAGS = @LDFLAGS@
LIBS = @LIBS@

CFLAGS += -fPIC
CFLAGS += -Wall
CFLAGS += -Wextra -Wpedantic
CFLAGS += $(addprefix -I,$(INCDIRS))
LDFLAGS += $(addprefix -L,$(LIBDIRS)) -shared

# Configure logging levels
LOG_DEBUG    = 10
LOG_INFO     = 20
LOG_WARNING  = 30
LOG_ERROR    = 40
LOG_CRITICAL = 50
CFLAGS += -DVS_LOG_LEVEL=$(LOG_INFO)
CFLAGS += -DVS_VPI_LOG_LEVEL=$(LOG_INFO)

# Optional features
CFLAGS += -DENABLE_ITX_POLLING

VPATH = $(SRCDIR)/src

SRCS = \
	cJSON.c \
	vs_msg.c \
	vs_server.c \
	vs_vpi.c \
	vs_vpi_get.c \
	vs_vpi_run.c \
	vs_utils.c \
	verisocks.c \
	verisocks_startup.c

OBJS = $(addprefix $(BUILDDIR)/,$(subst .c,.o,$(SRCS)))

all: $(LIBVPI)

$(LIBVPI): $(OBJS)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $^ @LIBS@

$(BUILDDIR)/%.o: %.c
	@mkdir -p $(BUILDDIR)
	$(CC) -o $@ -c $(CFLAGS) $<

.PHONY: clean all docs

docs:
	$(MAKE) -C $(DOCSDIR) html
	$(MAKE) -C $(DOCSDIR) doxygen

clean:
	-$(RM) $(OBJS)
	-$(RM) $(LIBVPI)
